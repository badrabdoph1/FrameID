{
  "name": "frameid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma db push --accept-data-loss && prisma db seed && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma db push --accept-data-loss && prisma db seed",
    "validate:env": "tsx scripts/validate-env.ts",
    "setup": "npm run validate:env && npm run db:deploy",
    "backup": "tsx src/scripts/backup-run.ts",
    "restore": "tsx src/scripts/backup-restore.ts",
    "backup:db": "tsx src/scripts/backup-run.ts DATABASE",
    "backup:uploads": "tsx src/scripts/backup-run.ts UPLOADS",
    "backup:full": "tsx src/scripts/backup-run.ts FULL",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.544.0",
    "next": "^15.5.0",
    "nodemailer": "^9.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.0",
    "jsdom": "^27.0.0",
    "prisma": "^6.16.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.23.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
