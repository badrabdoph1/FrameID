generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
  OPERATIONS_ADMIN
  BILLING_MANAGER
  TEMPLATE_MANAGER
  SUPPORT_AGENT
  SECURITY_AUDITOR
}

enum TenantStatus {
  TRIAL
  ACTIVE
  TRIAL_EXPIRED
  EXPIRED
  SUSPENDED
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  SUSPENDED
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum PaymentMethod {
  INSTAPAY
  VODAFONE_CASH
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  DRAFT
  SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum BackupType {
  DATABASE
  UPLOADS
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFICATION_FAILED
  UPLOAD_FAILED
}

enum SupportCaseStatus {
  OPEN
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum CustomerIssueStatus {
  NEW
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum CustomerIssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CustomerIssueSource {
  CUSTOMER_REPORT
  INTERNAL_AUTO
  ADMIN_REPORT
}

enum FeatureFlagScope {
  PLATFORM
  TENANT
  SITE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  passwordHash    String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  ownedTenants          Tenant[]
  // auditLogs removed: actorId stores plain ID, no FK to User
  adminNotes            AdminNote[]            @relation("AdminNoteAuthor")
  reviewedPayments      PaymentRequest[]       @relation("PaymentReviewer")
  // backupJobs removed: triggeredById stores plain ID, no FK to User
  // backupRestores removed: same reason
  impersonationSessions ImpersonationSession[] @relation("ImpersonationAdmin")
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  customerIssues        CustomerIssue[]        @relation("CustomerIssueReporter")

  @@index([role, deletedAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Tenant {
  id                String       @id @default(cuid())
  ownerUserId       String
  displayName       String
  status            TenantStatus @default(TRIAL)
  trialStartedAt    DateTime     @default(now())
  trialEndsAt       DateTime
  trialDays         Int          @default(14)
  gracePeriodEndsAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  owner                 User                   @relation(fields: [ownerUserId], references: [id])
  sites                 Site[]
  mediaAssets           MediaAsset[]
  subscriptions         Subscription[]
  payments              PaymentRequest[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  adminNotes            AdminNote[]
  supportCases          SupportCase[]
  lifecycleEvents       LifecycleEvent[]
  featureFlags          FeatureFlag[]
  impersonationSessions ImpersonationSession[]
  customerIssues        CustomerIssue[]

  @@index([ownerUserId, status])
}

model Site {
  id              String     @id @default(cuid())
  tenantId        String
  themeId         String
  slug            String     @unique
  slugChangeUsed  Boolean    @default(false)
  title           String
  description     String?
  templateCode    String?
  templateVersion String?
  status          SiteStatus @default(DRAFT)
  isPublished     Boolean    @default(false)
  publishedVersion Int       @default(1)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  theme            Theme             @relation(fields: [themeId], references: [id])
  domains          Domain[]
  themeConfigs     SiteThemeConfig[]
  sections         SiteSection[]
  galleryAlbums    GalleryAlbum[]
  contactProfile   ContactProfile?
  seoSettings      SEOSettings?
  lifecycleEvents  LifecycleEvent[]
  featureFlags     FeatureFlag[]
  packages         Package[]
  extraServices    ExtraService[]
  contentSnapshots SiteContentSnapshot[]
  customerIssues   CustomerIssue[]

  @@index([tenantId, status])
  @@index([themeId])
  @@index([templateCode, templateVersion])
}

model Theme {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String
  category      String?
  defaultConfig Json
  contentSchema Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  sites            Site[]
  templates        Template[]
  siteThemeConfigs SiteThemeConfig[]
}

model Template {
  id            String      @id @default(cuid())
  themeId       String
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String      @default("1.0.0")
  showroomOrder Int         @default(0)
  coverAssetId  String?
  previewData   Json?
  settings      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  theme Theme @relation(fields: [themeId], references: [id])

  @@index([themeId, showroomOrder])
}

model SiteContentSnapshot {
  id              String   @id @default(cuid())
  siteId          String
  reason          String
  templateCode    String?
  templateVersion String?
  data            Json
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([templateCode, templateVersion])
}

model SiteThemeConfig {
  id        String    @id @default(cuid())
  siteId    String
  themeId   String
  config    Json
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site  Site  @relation(fields: [siteId], references: [id])
  theme Theme @relation(fields: [themeId], references: [id])

  @@unique([siteId, themeId])
}

model Domain {
  id        String       @id @default(cuid())
  siteId    String
  hostname  String       @unique
  status    DomainStatus @default(PENDING)
  verifiedAt DateTime?
  createdAt DateTime     @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model SiteSection {
  id        String    @id @default(cuid())
  siteId    String
  type      String
  title     String
  data      Json
  sortOrder Int       @default(0)
  isVisible Boolean   @default(true)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, sortOrder])
}

model GalleryAlbum {
  id            String    @id @default(cuid())
  siteId        String
  title         String
  slug          String    @default("")
  description   String?
  coverAssetId  String?
  isVisible     Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  site   Site        @relation(fields: [siteId], references: [id])
  cover  MediaAsset? @relation("AlbumCover", fields: [coverAssetId], references: [id])
  images GalleryImage[]

  @@index([siteId, sortOrder])
  @@index([coverAssetId])
}

model GalleryImage {
  id         String    @id @default(cuid())
  albumId    String
  assetId    String
  caption    String?
  alt        String?
  sortOrder  Int       @default(0)
  isFeatured Boolean   @default(false)
  deletedAt  DateTime?

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  asset MediaAsset   @relation(fields: [assetId], references: [id])

  @@index([albumId, sortOrder])
  @@index([assetId])
}

model MediaAsset {
  id             String    @id @default(cuid())
  tenantId       String
  kind           String    @default("image")
  url            String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  width          Int?
  height         Int?
  alt            String?
  checksumSha256 String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  paymentProofs  PaymentRequest[]  @relation("PaymentProof")
  galleryImages  GalleryImage[]
  albumCovers    GalleryAlbum[]    @relation("AlbumCover")
  contactAvatars ContactProfile[]  @relation("ContactAvatar")
  contactCovers  ContactProfile[]  @relation("ContactCover")
  seoOgImages    SEOSettings[]     @relation("SEOOgImage")
  paymentQRCodes      PaymentAccount[]  @relation("PaymentQRCode")
  paymentSettingsQR   PaymentSettings[] @relation("PaymentQRCodeSettings")

  @@index([tenantId, kind, createdAt])
}

model ContactProfile {
  id                     String    @id @default(cuid())
  siteId                 String    @unique
  studioName             String?
  bio                    String?
  longDescription        String?
  phone                  String?
  whatsapp               String?
  email                  String?
  instagram              String?
  facebook               String?
  bookingMessageTemplate String?
  city                   String?
  country                String?
  address                String?
  googleMapsUrl          String?
  workingHours           Json?
  avatarAssetId          String?
  coverAssetId           String?
  tiktok                 String?
  snapchat               String?
  youtube                String?
  behance                String?
  fiveHundredPx          String?
  linkedin               String?
  telegram               String?
  xTwitter               String?
  threads                String?
  website                String?
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  site        Site        @relation(fields: [siteId], references: [id])
  avatarAsset MediaAsset? @relation("ContactAvatar", fields: [avatarAssetId], references: [id])
  coverAsset  MediaAsset? @relation("ContactCover", fields: [coverAssetId], references: [id])

  @@index([avatarAssetId])
  @@index([coverAssetId])
}

model SEOSettings {
  id                      String    @id @default(cuid())
  siteId                  String    @unique
  title                   String
  description             String?
  ogAssetId               String?
  robotsIndex             Boolean   @default(true)
  canonicalUrl            String?
  structuredDataOverrides Json?
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  site    Site        @relation(fields: [siteId], references: [id])
  ogAsset MediaAsset? @relation("SEOOgImage", fields: [ogAssetId], references: [id])

  @@index([ogAssetId])
}

model Package {
  id            String   @id @default(cuid())
  siteId        String
  name          String
  subtitle      String?
  priceAmount   Int
  currency      String   @default("EGP")
  features      Json
  imageUrl      String?
  isHighlighted Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  deletedAt     DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model ExtraService {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  description String?
  priceAmount Int
  currency    String   @default("EGP")
  iconKey     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  deletedAt   DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model LifecycleEvent {
  id        String   @id @default(cuid())
  tenantId  String
  siteId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site?  @relation(fields: [siteId], references: [id])

  @@index([tenantId, createdAt])
}

model Plan {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  priceAmount     Int
  currency        String   @default("EGP")
  billingInterval String
  features        Json
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  subscriptions   Subscription[]
  paymentRequests PaymentRequest[]
  changesFrom     SubscriptionChange[] @relation("FromPlan")
  changesTo       SubscriptionChange[] @relation("ToPlan")

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  planId             String?
  status             SubscriptionStatus @default(TRIAL)
  activatedAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  expiresAt          DateTime?
  cancelledAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  plan           Plan?            @relation(fields: [planId], references: [id])
  paymentRequests PaymentRequest[]

  @@index([tenantId, status])
  @@index([expiresAt])
}

model SubscriptionChange {
  id             String    @id @default(cuid())
  tenantId       String
  subscriptionId String?
  fromPlanId     String?
  toPlanId       String?
  fromStatus     String?
  toStatus       String?
  changeType     String?
  initiatedById  String?
  reason         String?
  createdAt      DateTime  @default(now())

  fromPlan Plan? @relation("FromPlan", fields: [fromPlanId], references: [id])
  toPlan   Plan? @relation("ToPlan", fields: [toPlanId], references: [id])
}

model PaymentRequest {
  id                String        @id @default(cuid())
  tenantId          String
  subscriptionId    String?
  planId            String?
  paymentAccountId  String?
  amount            Int
  currency          String        @default("EGP")
  method            PaymentMethod
  status            PaymentStatus @default(DRAFT)
  reference         String?
  submittedAt       DateTime?
  note              String?
  adminNote         String?
  rejectionReason   String?
  proofAssetId      String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now())
  deletedAt         DateTime?

  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  plan           Plan?         @relation(fields: [planId], references: [id])
  paymentAccount PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  proofAsset     MediaAsset?   @relation("PaymentProof", fields: [proofAssetId], references: [id])
  reviewer       User?         @relation("PaymentReviewer", fields: [reviewedByUserId], references: [id])
  logs           PaymentRequestLog[]

  @@index([tenantId, status])
  @@index([subscriptionId])
  @@index([paymentAccountId])
  @@index([proofAssetId])
}

model PaymentRequestLog {
  id               String         @id @default(cuid())
  paymentRequestId String
  fromStatus       PaymentStatus?
  toStatus         PaymentStatus?
  action           String         @default("STATUS_CHANGED")
  actorUserId      String?
  actorName        String?
  note             String?
  metadata         Json?
  createdAt        DateTime       @default(now())

  request PaymentRequest @relation(fields: [paymentRequestId], references: [id])

  @@index([paymentRequestId, createdAt])
}

model PaymentAccount {
  id                String        @id @default(cuid())
  paymentSettingsId String?
  method            PaymentMethod @default(INSTAPAY)
  displayName       String        @default("")
  accountIdentifier String        @default("")
  label             String?
  accountName       String        @default("")
  accountNumber     String        @default("")
  iban              String?
  swift             String?
  phoneNumber       String?
  bankName          String?
  instructions      String?
  notes             String?
  qrAssetId         String?
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  deletedAt         DateTime?

  paymentSettings PaymentSettings? @relation(fields: [paymentSettingsId], references: [id])
  qrAsset         MediaAsset?      @relation("PaymentQRCode", fields: [qrAssetId], references: [id])
  requests        PaymentRequest[]

  @@index([paymentSettingsId])
  @@index([method, isActive, sortOrder])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant  Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?
  // actorId stores AdminUser or User ID (no FK — admins ≠ users)

  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  priority  String?   @default("info")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, readAt, createdAt])
}

model NotificationLog {
  id        String    @id @default(cuid())
  tenantId  String?
  category  String?
  type      String
  title     String
  body      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([tenantId, category, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         UserRole @default(SUPER_ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions               AdminSession[]
  assignedCustomerIssues CustomerIssue[]      @relation("CustomerIssueAssignee")
  resolvedCustomerIssues CustomerIssue[]      @relation("CustomerIssueResolver")
  customerIssueEvents    CustomerIssueEvent[] @relation("CustomerIssueEventActor")
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
}

model AdminNote {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("AdminNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
}

model ImpersonationSession {
  id        String   @id @default(cuid())
  adminId   String
  tenantId  String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  admin  User   @relation("ImpersonationAdmin", fields: [adminId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([adminId, createdAt])
  @@index([tenantId, createdAt])
}

model SupportCase {
  id          String            @id @default(cuid())
  tenantId    String
  openedById  String?
  status      SupportCaseStatus @default(OPEN)
  subject     String
  description String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  key       String
  scope     FeatureFlagScope @default(PLATFORM)
  tenantId  String?
  siteId    String?
  enabled   Boolean          @default(false)
  value     Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  site   Site?   @relation(fields: [siteId], references: [id])

  @@unique([key, scope, tenantId, siteId])
}

model BackupJob {
  id               String       @id @default(cuid())
  type             BackupType
  status           BackupStatus @default(PENDING)
  triggeredById    String?
  filePath         String?
  sizeBytes        Int?
  checksumSha256   String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  completedAt      DateTime?

  // triggeredById stores the AdminUser or User ID that initiated the backup (no FK — admins ≠ users)

  @@index([status, createdAt])
}

model PaymentSettings {
  id              String        @id @default(cuid())
  paymentMethod   PaymentMethod @unique
  isActive        Boolean       @default(true)
  label           String?
  description     String?
  config          Json          @default("{}")
  qrCodeAssetId   String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  accounts PaymentAccount[]
  qrCodeAsset MediaAsset? @relation("PaymentQRCodeSettings", fields: [qrCodeAssetId], references: [id])

  @@index([isActive, sortOrder])
}

model BackupSettings {
  type            String   @id
  enabled         Boolean  @default(true)
  schedule        String   @default("0 2 * * *")
  retentionCount  Int      @default(7)
  compression     String?  @default("zstd")
  encryption      Boolean? @default(true)
  githubBranch    String?  @default("platform-backups")
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RestoreJob {
  id              String       @id @default(cuid())
  backupJobId     String
  status          BackupStatus @default(PENDING)
  triggeredById   String?
  targetDatabase  String?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  // triggeredById stores the AdminUser or User ID that initiated the restore (no FK — admins ≠ users)

  @@index([status, createdAt])
}

model ErrorLog {
  id               String    @id @default(cuid())
  issueId          String?
  category         String
  level            String
  code             String?
  errorType        String?
  message          String
  fingerprint      String?
  requestId        String?
  correlationId    String?
  route            String?
  method           String?
  url              String?
  stack            String?
  digest           String?
  cause            String?
  userId           String?
  tenantId         String?
  siteId           String?
  sessionId        String?
  adminUserId      String?
  sourceArea       String?
  sourceFile       String?
  sourceLine       Int?
  sourceColumn     Int?
  ipAddress        String?
  userAgent        String?
  browser          String?
  device           String?
  os               String?
  language         String?
  timezone         String?
  screenSize       String?
  referrer         String?
  connectionStatus String?
  environment      String?
  releaseVersion   String?
  buildVersion     String?
  templateCode     String?
  lastAction       String?
  metadata         Json?
  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?
  resolutionNote   String?
  createdAt        DateTime  @default(now())

  issue CustomerIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([category, level])
  @@index([createdAt])
  @@index([resolved])
  @@index([fingerprint, createdAt])
  @@index([issueId, createdAt])
  @@index([tenantId, siteId, createdAt])
}

model CustomerIssue {
  id                      String                @id @default(cuid())
  number                  Int                   @unique @default(autoincrement())
  status                  CustomerIssueStatus   @default(NEW)
  priority                CustomerIssuePriority @default(MEDIUM)
  source                  CustomerIssueSource   @default(CUSTOMER_REPORT)
  title                   String
  fingerprint             String
  customerNote            String?
  resolutionNote          String?
  userId                  String?
  tenantId                String?
  siteId                  String?
  sessionId               String?
  assigneeAdminUserId     String?
  resolvedByAdminUserId   String?
  occurrenceCount         Int                   @default(1)
  lastSeenAt              DateTime              @default(now())
  reviewStartedAt         DateTime?
  resolvedAt              DateTime?
  closedAt                DateTime?
  customerNotifiedAt      DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  reporter       User?                @relation("CustomerIssueReporter", fields: [userId], references: [id], onDelete: SetNull)
  tenant         Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  site           Site?                @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assignee       AdminUser?           @relation("CustomerIssueAssignee", fields: [assigneeAdminUserId], references: [id], onDelete: SetNull)
  resolvedBy     AdminUser?           @relation("CustomerIssueResolver", fields: [resolvedByAdminUserId], references: [id], onDelete: SetNull)
  occurrences    ErrorLog[]
  events         CustomerIssueEvent[]

  @@index([status, priority, createdAt])
  @@index([fingerprint, status, updatedAt])
  @@index([tenantId, siteId, status])
  @@index([userId, status])
  @@index([assigneeAdminUserId, status])
}

model CustomerIssueEvent {
  id           String   @id @default(cuid())
  issueId      String
  actorAdminId String?
  type         String
  fromStatus   String?
  toStatus     String?
  note         String?
  metadata     Json?
  createdAt    DateTime @default(now())

  issue CustomerIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor AdminUser?    @relation("CustomerIssueEventActor", fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([issueId, createdAt])
  @@index([actorAdminId, createdAt])
}
