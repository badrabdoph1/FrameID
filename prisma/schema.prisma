generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
  OPERATIONS_ADMIN
  BILLING_MANAGER
  TEMPLATE_MANAGER
  SUPPORT_AGENT
  SECURITY_AUDITOR
}

enum TenantStatus {
  TRIAL
  ACTIVE
  TRIAL_EXPIRED
  EXPIRED
  SUSPENDED
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  SUSPENDED
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum PaymentMethod {
  INSTAPAY
  VODAFONE_CASH
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  DRAFT
  SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum BackupType {
  DATABASE
  UPLOADS
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFICATION_FAILED
  UPLOAD_FAILED
}

enum SupportCaseStatus {
  OPEN
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum CustomerIssueStatus {
  NEW
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum CustomerIssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CustomerIssueSource {
  CUSTOMER_REPORT
  INTERNAL_AUTO
  ADMIN_REPORT
}

enum FeatureFlagScope {
  PLATFORM
  TENANT
  SITE
}

enum PlatformPageKind {
  EDITORIAL
  LEGAL
  AUTH
  FUNCTIONAL
}

enum OperationType {
  MEDIA_SCAN
  MEDIA_CLEANUP
  MEDIA_PURGE
  MEDIA_RESTORE
  MEDIA_RESYNC
  MEDIA_REPAIR
  MEDIA_THUMBNAIL_REBUILD
  MEDIA_COMPRESSION
  BACKUP_INTEGRITY_CHECK
}

enum OperationStatus {
  PENDING
  RUNNING
  PAUSE_REQUESTED
  PAUSED
  CANCEL_REQUESTED
  CANCELLED
  SUCCEEDED
  PARTIAL
  FAILED
}

enum OperationItemStatus {
  PENDING
  RUNNING
  SKIPPED
  SUCCEEDED
  FAILED
  CANCELLED
}

enum OperationEventLevel {
  DEBUG
  INFO
  WARNING
  ERROR
}

enum MediaLifecycleStatus {
  ACTIVE
  IN_TRASH
  PURGED
}

enum MediaUsageStatus {
  USED
  UNUSED
  UNKNOWN
}

enum MediaCatalogSource {
  CUSTOMER_MEDIA
  PLATFORM_MEDIA
  STATIC_FILE
  STORAGE_OBJECT
  BACKUP_OBJECT
}

enum MediaFindingType {
  UNUSED_MEDIA
  DUPLICATE_MEDIA
  CORRUPT_MEDIA
  MISSING_OBJECT
  MISSING_DATABASE_RECORD
  DATABASE_REFERENCE_MISSING_OBJECT
  OVERSIZED_MEDIA
  INVALID_DIMENSIONS
  STORAGE_BACKUP_MISMATCH
}

enum MediaFindingSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum MediaFindingStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum CommunicationConversationMode {
  DIRECT
  BROADCAST
}

enum CommunicationLifecycleState {
  ACTIVE
  ARCHIVED
  WITHDRAWN
}

enum CommunicationReplyMode {
  ENABLED
  DISABLED
  PRIVATE_BRANCH
}

enum CommunicationActorType {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum CommunicationEntryKind {
  MESSAGE
  INTERNAL_NOTE
  STATE_CHANGE
  ASSIGNMENT
  SYSTEM_EVENT
  CORRECTION
}

enum CommunicationVisibility {
  CUSTOMER_AND_ADMIN
  ADMIN_ONLY
}

enum CommunicationWorkItemStatus {
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_INTERNAL
  RESOLVED
  CLOSED
}

enum CommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CommunicationWorkItemEventType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  QUEUE_CHANGED
}

enum CommunicationAttachmentScanStatus {
  PENDING
  PROCESSING
  CLEAN
  REJECTED
  DELETED
}

enum CommunicationCampaignStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  WITHDRAWN
  CANCELLED
}

enum CommunicationOutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  DEAD_LETTER
}

enum CommunicationDeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  passwordHash    String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  ownedTenants                      Tenant[]
  // auditLogs removed: actorId stores plain ID, no FK to User
  adminNotes                        AdminNote[]                  @relation("AdminNoteAuthor")
  // reviewedPayments: PaymentRequest FK removed — reviewedByUserId stores AdminUser or User ID (no FK — admins ≠ users)
  // backupJobs removed: triggeredById stores plain ID, no FK to User
  // backupRestores removed: same reason
  sessions                          Session[]
  passwordResetTokens               PasswordResetToken[]
  customerIssues                    CustomerIssue[]              @relation("CustomerIssueReporter")
  communicationConversationsCreated CommunicationConversation[]  @relation("CommunicationConversationCustomerCreator")
  communicationEntries              CommunicationEntry[]         @relation("CommunicationEntryCustomerAuthor")
  communicationReadCursors          CommunicationReadCursor[]    @relation("CommunicationReadCursorCustomer")
  communicationAttachmentsUploaded  CommunicationAttachment[]    @relation("CommunicationAttachmentCustomerUploader")
  communicationWorkItemEvents       CommunicationWorkItemEvent[] @relation("CommunicationWorkItemEventCustomerActor")

  @@index([role, deletedAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Tenant {
  id                String       @id @default(cuid())
  ownerUserId       String
  displayName       String
  status            TenantStatus @default(TRIAL)
  trialStartedAt    DateTime     @default(now())
  trialEndsAt       DateTime
  trialDays         Int          @default(14)
  gracePeriodEndsAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  owner                      User                        @relation(fields: [ownerUserId], references: [id])
  sites                      Site[]
  mediaAssets                MediaAsset[]
  subscriptions              Subscription[]
  payments                   PaymentRequest[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  adminNotes                 AdminNote[]
  supportCases               SupportCase[]
  lifecycleEvents            LifecycleEvent[]
  featureFlags               FeatureFlag[]
  impersonationSessions      ImpersonationSession[]
  customerIssues             CustomerIssue[]
  customerRequests           CustomerRequest[]
  customerMessageRecipients  CustomerMessageRecipient[]
  communicationConversations CommunicationConversation[]
  communicationAudiences     CommunicationAudience[]

  @@index([ownerUserId, status])
}

enum CustomerRequestStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum CustomerRequestType {
  ACCOUNT_DELETION
  FEATURE_ACTIVATION
  UPGRADE
  ADDITIONAL_SERVICE
  OTHER
}

model Site {
  id                 String     @id @default(cuid())
  tenantId           String
  themeId            String
  slug               String
  slugChangeUsed     Boolean    @default(false)
  templateChangeUsed Boolean    @default(false)
  title              String
  description        String?
  templateCode       String?
  templateVersion    String?
  status             SiteStatus @default(DRAFT)
  isPublished        Boolean    @default(false)
  publishedVersion   Int        @default(1)
  publishedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  theme            Theme                 @relation(fields: [themeId], references: [id])
  domains          Domain[]
  themeConfigs     SiteThemeConfig[]
  sections         SiteSection[]
  galleryAlbums    GalleryAlbum[]
  contactProfile   ContactProfile?
  seoSettings      SEOSettings?
  lifecycleEvents  LifecycleEvent[]
  featureFlags     FeatureFlag[]
  packages         Package[]
  extraServices    ExtraService[]
  contentSnapshots SiteContentSnapshot[]
  customerIssues   CustomerIssue[]
  customerRequests CustomerRequest[]

  @@unique([slug, deletedAt])
  @@index([tenantId, status])
  @@index([themeId])
  @@index([templateCode, templateVersion])
}

model Theme {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String
  category      String?
  defaultConfig Json
  contentSchema Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  sites            Site[]
  templates        Template[]
  siteThemeConfigs SiteThemeConfig[]
}

model Template {
  id            String      @id @default(cuid())
  themeId       String
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String      @default("1.0.0")
  showroomOrder Int         @default(0)
  coverAssetId  String?
  previewData   Json?
  settings      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  theme Theme @relation(fields: [themeId], references: [id])

  @@index([themeId, showroomOrder])
}

model SiteContentSnapshot {
  id              String   @id @default(cuid())
  siteId          String
  reason          String
  templateCode    String?
  templateVersion String?
  data            Json
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([templateCode, templateVersion])
}

model SiteThemeConfig {
  id        String    @id @default(cuid())
  siteId    String
  themeId   String
  config    Json
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site  Site  @relation(fields: [siteId], references: [id])
  theme Theme @relation(fields: [themeId], references: [id])

  @@unique([siteId, themeId])
}

model Domain {
  id         String       @id @default(cuid())
  siteId     String
  hostname   String       @unique
  status     DomainStatus @default(PENDING)
  verifiedAt DateTime?
  createdAt  DateTime     @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model SiteSection {
  id        String    @id @default(cuid())
  siteId    String
  type      String
  title     String
  data      Json
  sortOrder Int       @default(0)
  isVisible Boolean   @default(true)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, sortOrder])
}

model GalleryAlbum {
  id           String    @id @default(cuid())
  siteId       String
  title        String
  slug         String    @default("")
  description  String?
  coverAssetId String?
  isVisible    Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  site   Site           @relation(fields: [siteId], references: [id])
  cover  MediaAsset?    @relation("AlbumCover", fields: [coverAssetId], references: [id])
  images GalleryImage[]

  @@index([siteId, sortOrder])
  @@index([coverAssetId])
}

model GalleryImage {
  id         String    @id @default(cuid())
  albumId    String
  assetId    String
  caption    String?
  alt        String?
  sortOrder  Int       @default(0)
  isFeatured Boolean   @default(false)
  deletedAt  DateTime?

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  asset MediaAsset   @relation(fields: [assetId], references: [id])

  @@index([albumId, sortOrder])
  @@index([assetId])
}

model MediaAsset {
  id             String    @id @default(cuid())
  tenantId       String
  kind           String    @default("image")
  url            String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  width          Int?
  height         Int?
  alt            String?
  checksumSha256 String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  paymentProofs     PaymentRequest[]  @relation("PaymentProof")
  galleryImages     GalleryImage[]
  albumCovers       GalleryAlbum[]    @relation("AlbumCover")
  contactAvatars    ContactProfile[]  @relation("ContactAvatar")
  contactCovers     ContactProfile[]  @relation("ContactCover")
  seoOgImages       SEOSettings[]     @relation("SEOOgImage")
  paymentQRCodes    PaymentAccount[]  @relation("PaymentQRCode")
  paymentSettingsQR PaymentSettings[] @relation("PaymentQRCodeSettings")

  @@index([tenantId, kind, createdAt])
}

model ContactProfile {
  id                     String    @id @default(cuid())
  siteId                 String    @unique
  studioName             String?
  bio                    String?
  longDescription        String?
  phone                  String?
  whatsapp               String?
  email                  String?
  instagram              String?
  facebook               String?
  bookingMessageTemplate String?
  city                   String?
  country                String?
  address                String?
  googleMapsUrl          String?
  workingHours           Json?
  avatarAssetId          String?
  coverAssetId           String?
  tiktok                 String?
  workLocation           String?   @default("فريلانسر")
  snapchat               String?
  youtube                String?
  behance                String?
  fiveHundredPx          String?
  linkedin               String?
  telegram               String?
  xTwitter               String?
  threads                String?
  website                String?
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  site        Site        @relation(fields: [siteId], references: [id])
  avatarAsset MediaAsset? @relation("ContactAvatar", fields: [avatarAssetId], references: [id])
  coverAsset  MediaAsset? @relation("ContactCover", fields: [coverAssetId], references: [id])

  @@index([avatarAssetId])
  @@index([coverAssetId])
}

model SEOSettings {
  id                      String    @id @default(cuid())
  siteId                  String    @unique
  title                   String
  description             String?
  ogAssetId               String?
  robotsIndex             Boolean   @default(true)
  canonicalUrl            String?
  structuredDataOverrides Json?
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  site    Site        @relation(fields: [siteId], references: [id])
  ogAsset MediaAsset? @relation("SEOOgImage", fields: [ogAssetId], references: [id])

  @@index([ogAssetId])
}

model Package {
  id            String    @id @default(cuid())
  siteId        String
  name          String
  subtitle      String?
  priceAmount   Int
  currency      String    @default("EGP")
  features      Json
  imageUrl      String?
  isHighlighted Boolean   @default(false)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  deletedAt     DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model ExtraService {
  id          String    @id @default(cuid())
  siteId      String
  name        String
  description String?
  priceAmount Int
  currency    String    @default("EGP")
  iconKey     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  deletedAt   DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model LifecycleEvent {
  id        String   @id @default(cuid())
  tenantId  String
  siteId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site?  @relation(fields: [siteId], references: [id])

  @@index([tenantId, createdAt])
}

model Plan {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  priceAmount     Int
  currency        String               @default("EGP")
  billingInterval String
  features        Json
  isActive        Boolean              @default(true)
  sortOrder       Int                  @default(0)
  subscriptions   Subscription[]
  paymentRequests PaymentRequest[]
  changesFrom     SubscriptionChange[] @relation("FromPlan")
  changesTo       SubscriptionChange[] @relation("ToPlan")

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  planId             String?
  status             SubscriptionStatus @default(TRIAL)
  activatedAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  expiresAt          DateTime?
  cancelledAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  plan            Plan?            @relation(fields: [planId], references: [id])
  paymentRequests PaymentRequest[]

  @@index([tenantId, status])
  @@index([expiresAt])
}

model SubscriptionChange {
  id             String   @id @default(cuid())
  tenantId       String
  subscriptionId String?
  fromPlanId     String?
  toPlanId       String?
  fromStatus     String?
  toStatus       String?
  changeType     String?
  initiatedById  String?
  reason         String?
  createdAt      DateTime @default(now())

  fromPlan Plan? @relation("FromPlan", fields: [fromPlanId], references: [id])
  toPlan   Plan? @relation("ToPlan", fields: [toPlanId], references: [id])
}

model PaymentRequest {
  id               String        @id @default(cuid())
  tenantId         String
  subscriptionId   String?
  planId           String?
  paymentAccountId String?
  amount           Int
  currency         String        @default("EGP")
  method           PaymentMethod
  status           PaymentStatus @default(DRAFT)
  reference        String?
  submittedAt      DateTime?
  note             String?
  adminNote        String?
  rejectionReason  String?
  proofAssetId     String?
  reviewedByUserId  String?       @map("reviewedById")
  reviewedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now())
  deletedAt        DateTime?

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  subscription   Subscription?       @relation(fields: [subscriptionId], references: [id])
  plan           Plan?               @relation(fields: [planId], references: [id])
  paymentAccount PaymentAccount?     @relation(fields: [paymentAccountId], references: [id])
  proofAsset     MediaAsset?         @relation("PaymentProof", fields: [proofAssetId], references: [id])
  // reviewer FK removed — reviewedByUserId stores AdminUser or User ID (no FK — admins ≠ users)
  logs           PaymentRequestLog[]

  @@index([tenantId, status])
  @@index([subscriptionId])
  @@index([paymentAccountId])
  @@index([proofAssetId])
  @@index([reviewedByUserId])
}

model PaymentRequestLog {
  id               String         @id @default(cuid())
  paymentRequestId String
  fromStatus       PaymentStatus?
  toStatus         PaymentStatus?
  action           String         @default("STATUS_CHANGED")
  actorUserId      String?
  actorName        String?
  note             String?
  metadata         Json?
  createdAt        DateTime       @default(now())

  request PaymentRequest @relation(fields: [paymentRequestId], references: [id])

  @@index([paymentRequestId, createdAt])
}

model PaymentAccount {
  id                String        @id @default(cuid())
  paymentSettingsId String?
  method            PaymentMethod @default(INSTAPAY)
  displayName       String        @default("")
  accountIdentifier String        @default("")
  label             String?
  accountName       String        @default("")
  accountNumber     String        @default("")
  iban              String?
  swift             String?
  phoneNumber       String?
  bankName          String?
  instructions      String?
  notes             String?
  qrAssetId         String?
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  deletedAt         DateTime?

  paymentSettings PaymentSettings? @relation(fields: [paymentSettingsId], references: [id])
  qrAsset         MediaAsset?      @relation("PaymentQRCode", fields: [qrAssetId], references: [id])
  requests        PaymentRequest[]

  @@index([paymentSettingsId])
  @@index([method, isActive, sortOrder])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?
  // actorId stores AdminUser or User ID (no FK — admins ≠ users)

  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  priority  String?   @default("info")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, readAt, createdAt])
}

model NotificationLog {
  id        String    @id @default(cuid())
  tenantId  String?
  category  String?
  type      String
  title     String
  body      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([tenantId, category, createdAt])
}

model CustomerMessageCampaign {
  id               String    @id @default(cuid())
  title            String
  body             String
  tone             String    @default("info")
  status           String    @default("ACTIVE")
  audienceMode     String
  audienceSnapshot Json?
  createdByAdminId String
  createdByName    String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  pausedAt         DateTime?

  recipients CustomerMessageRecipient[]

  @@index([status, createdAt])
  @@index([createdByAdminId, createdAt])
}

model CustomerMessageRecipient {
  id         String   @id @default(cuid())
  campaignId String
  tenantId   String?
  tenantName String
  ownerName  String
  ownerEmail String
  createdAt  DateTime @default(now())

  campaign CustomerMessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant   Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([campaignId, tenantId])
  @@index([tenantId, createdAt])
  @@index([campaignId, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         UserRole @default(SUPER_ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions                          AdminSession[]
  assignedCustomerIssues            CustomerIssue[]              @relation("CustomerIssueAssignee")
  resolvedCustomerIssues            CustomerIssue[]              @relation("CustomerIssueResolver")
  customerIssueEvents               CustomerIssueEvent[]         @relation("CustomerIssueEventActor")
  communicationConversationsCreated CommunicationConversation[]  @relation("CommunicationConversationAdminCreator")
  communicationEntries              CommunicationEntry[]         @relation("CommunicationEntryAdminAuthor")
  communicationReadCursors          CommunicationReadCursor[]    @relation("CommunicationReadCursorAdmin")
  communicationWorkItemsAssigned    CommunicationWorkItem[]      @relation("CommunicationWorkItemAssignee")
  communicationWorkItemEvents       CommunicationWorkItemEvent[] @relation("CommunicationWorkItemEventAdminActor")
  communicationAttachmentsUploaded  CommunicationAttachment[]    @relation("CommunicationAttachmentAdminUploader")
  communicationCampaignsCreated     CommunicationCampaign[]      @relation("CommunicationCampaignCreator")
  // reviewedCustomerRequests removed: same reason as ImpersonationSession — no FK.
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
}

model AdminNote {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("AdminNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
}

model ImpersonationSession {
