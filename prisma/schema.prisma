}

model CommunicationDeliveryAttempt {
  id                String                      @id @default(cuid())
  outboxEventId     String
  tenantId          String?
  channelKey        String
  recipientKey      String
  idempotencyKey    String                      @unique
  status            CommunicationDeliveryStatus @default(PENDING)
  attempts          Int                         @default(0)
  providerMessageId String?
  availableAt       DateTime                    @default(now())
  leaseOwner        String?
  leaseExpiresAt    DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  lastErrorCode     String?
  lastError         String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  outboxEvent CommunicationOutboxEvent @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)

  @@index([status, availableAt, leaseExpiresAt])
  @@index([outboxEventId, channelKey])
  @@index([tenantId, channelKey, createdAt])
}
