generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
  OPERATIONS_ADMIN
  BILLING_MANAGER
  TEMPLATE_MANAGER
  SUPPORT_AGENT
  SECURITY_AUDITOR
}

enum TenantStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  SUSPENDED
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum PaymentMethod {
  INSTAPAY
  VODAFONE_CASH
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  DRAFT
  SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum BackupType {
  DATABASE
  UPLOADS
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFICATION_FAILED
  UPLOAD_FAILED
}

enum SupportCaseStatus {
  OPEN
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum FeatureFlagScope {
  PLATFORM
  TENANT
  SITE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  passwordHash    String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  ownedTenants          Tenant[]
  auditLogs             AuditLog[]             @relation("AuditActor")
  adminNotes            AdminNote[]            @relation("AdminNoteAuthor")
  reviewedPayments      PaymentRequest[]       @relation("PaymentReviewer")
  backupJobs            BackupJob[]            @relation("BackupInitiator")
  backupRestores        RestoreJob[]           @relation("RestoreInitiator")
  impersonationSessions ImpersonationSession[] @relation("ImpersonationAdmin")
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]

  @@index([role, deletedAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Tenant {
  id             String       @id @default(cuid())
  ownerUserId    String
  displayName    String
  status         TenantStatus @default(TRIAL)
  trialStartedAt DateTime     @default(now())
  trialEndsAt    DateTime
  trialDays      Int          @default(14)
  gracePeriodEndsAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  owner                 User                   @relation(fields: [ownerUserId], references: [id])
  sites                 Site[]
  mediaAssets           MediaAsset[]
  subscriptions         Subscription[]
  payments              PaymentRequest[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  adminNotes            AdminNote[]
  supportCases          SupportCase[]
  featureFlags          FeatureFlag[]
  impersonationSessions ImpersonationSession[]

  @@index([ownerUserId])
  @@index([status, deletedAt])
}

model Site {
  id               String     @id @default(cuid())
  tenantId         String
  themeId          String
  slug             String     @unique
  slugChangeUsed   Boolean    @default(false)
  title            String
  description      String?
  status           SiteStatus @default(DRAFT)
  locale           String     @default("ar")
  isPublished      Boolean    @default(false)
  publishedVersion Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  theme        Theme            @relation(fields: [themeId], references: [id])
  domains      SiteDomain[]
  themeConfig  SiteThemeConfig?
  sections     SiteSection[]
  packages     Package[]
  extras       ExtraService[]
  albums       GalleryAlbum[]
  contact      ContactProfile?
  seoSettings  SEOSettings?
  featureFlags FeatureFlag[]

  @@index([tenantId, status, deletedAt])
  @@index([themeId])
}

model SiteDomain {
  id                String       @id @default(cuid())
  siteId            String
  domain            String       @unique
  status            DomainStatus @default(PENDING)
  verificationToken String
  verifiedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model Theme {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String
  category      String
  defaultConfig Json
  contentSchema Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  sites       Site[]
  templates   Template[]
  siteConfigs SiteThemeConfig[]

  @@index([status, deletedAt])
}

model Template {
  id            String      @id @default(cuid())
  themeId       String
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  showroomOrder Int         @default(100)
  previewData   Json
  settings      Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  theme Theme @relation(fields: [themeId], references: [id])

  @@index([themeId])
  @@index([status, showroomOrder, deletedAt])
}

model SiteThemeConfig {
  id        String    @id @default(cuid())
  siteId    String    @unique
  themeId   String
  config    Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site  Site  @relation(fields: [siteId], references: [id])
  theme Theme @relation(fields: [themeId], references: [id])

  @@index([themeId])
}

model SiteSection {
  id        String    @id @default(cuid())
  siteId    String
  type      String
  title     String?
  data      Json
  sortOrder Int       @default(0)
  isVisible Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, deletedAt, sortOrder])
}

model Package {
  id            String    @id @default(cuid())
  siteId        String
  name          String
  subtitle      String?
  priceAmount   Int
  currency      String    @default("EGP")
  features      Json
  imageAssetId  String?
  isHighlighted Boolean   @default(false)
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  site       Site        @relation(fields: [siteId], references: [id])
  imageAsset MediaAsset? @relation("PackageImage", fields: [imageAssetId], references: [id])

  @@index([siteId, deletedAt, sortOrder])
  @@index([imageAssetId])
}

model ExtraService {
  id          String    @id @default(cuid())
  siteId      String
  name        String
  priceAmount Int
  currency    String    @default("EGP")
  iconKey     String?
  description String?
  imageAssetId String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  isHighlighted Boolean @default(false)
  deletedAt   DateTime?

  site       Site        @relation(fields: [siteId], references: [id])
  imageAsset MediaAsset? @relation("ExtraImage", fields: [imageAssetId], references: [id])

  @@index([siteId, sortOrder])
}

model GalleryAlbum {
  id           String    @id @default(cuid())
  siteId       String
  title        String
  slug         String
  description  String?
  coverAssetId String?
  sortOrder    Int       @default(0)
  isVisible    Boolean   @default(true)
  deletedAt    DateTime?

  site       Site           @relation(fields: [siteId], references: [id])
  coverAsset MediaAsset?    @relation("AlbumCover", fields: [coverAssetId], references: [id])
  images     GalleryImage[]

  @@unique([siteId, slug])
  @@index([siteId, sortOrder])
  @@index([coverAssetId])
}

model MediaAsset {
  id            String    @id @default(cuid())
  tenantId      String
  storageKey    String    @unique
  url           String
  mimeType      String
  width         Int?
  height        Int?
  sizeBytes     Int
  blurHash      String?
  dominantColor String?
  alt           String?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  packageImages Package[]        @relation("PackageImage")
  extraImages   ExtraService[]   @relation("ExtraImage")
  albumCovers   GalleryAlbum[]   @relation("AlbumCover")
  galleryImages GalleryImage[]
  seoImages     SEOSettings[]    @relation("SEOOgImage")
  paymentProofs PaymentRequest[] @relation("PaymentProof")
  contactAvatar ContactProfile[] @relation("ContactAvatar")
  contactCover  ContactProfile[] @relation("ContactCover")
  paymentQRCodes PaymentSettings[] @relation("PaymentQRCode")

  @@index([tenantId, deletedAt, createdAt])
}

model GalleryImage {
  id        String    @id @default(cuid())
  albumId   String
  assetId   String
  caption   String?
  sortOrder Int       @default(0)
  isFeatured Boolean  @default(false)
  deletedAt DateTime?

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  asset MediaAsset   @relation(fields: [assetId], references: [id])

  @@index([albumId, sortOrder])
  @@index([assetId])
}

model ContactProfile {
  id                     String    @id @default(cuid())
  siteId                 String    @unique
  phone                  String?
  whatsapp               String?
  email                  String?
  instagram              String?
  facebook               String?
  locationLabel          String?
  bookingMessageTemplate String?

  // New extended fields
  studioName             String?
  bio                    String?
  longDescription        String?
  city                   String?
  country                String?
  address                String?
  googleMapsUrl          String?
  workingHours           Json?
  avatarAssetId          String?
  coverAssetId           String?

  // Social links
  tiktok                 String?
  snapchat               String?
  youtube                String?
  behance                String?
  fiveHundredPx          String?
  linkedin               String?
  telegram               String?
  xTwitter               String?
  threads                String?
  website                String?

  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  site       Site        @relation(fields: [siteId], references: [id])
  avatarAsset MediaAsset? @relation("ContactAvatar", fields: [avatarAssetId], references: [id])
  coverAsset  MediaAsset? @relation("ContactCover", fields: [coverAssetId], references: [id])

  @@index([avatarAssetId])
  @@index([coverAssetId])
}

model SEOSettings {
  id                      String    @id @default(cuid())
  siteId                  String    @unique
  title                   String
  description             String?
  ogAssetId               String?
  robotsIndex             Boolean   @default(true)
  canonicalUrl            String?
  structuredDataOverrides Json?
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  site    Site        @relation(fields: [siteId], references: [id])
  ogAsset MediaAsset? @relation("SEOOgImage", fields: [ogAssetId], references: [id])

  @@index([ogAssetId])
}

model Plan {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  priceAmount     Int
  currency        String    @default("EGP")
  billingInterval String
  features        Json
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  subscriptions     Subscription[]
  paymentRequests   PaymentRequest[]
  fromChanges       SubscriptionChange[] @relation("FromPlan")
  toChanges         SubscriptionChange[] @relation("ToPlan")
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  planId             String?
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  activatedAt        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  plan     Plan?            @relation(fields: [planId], references: [id])
  payments PaymentRequest[]
  changes  SubscriptionChange[]

  @@index([tenantId, status, deletedAt])
}

model PaymentRequest {
  id               String        @id @default(cuid())
  tenantId         String
  subscriptionId   String
  planId           String?
  method           PaymentMethod
  paymentAccountId String?
  amount           Int
  currency         String        @default("EGP")
  status           PaymentStatus @default(DRAFT)
  reference        String?
  proofAssetId     String?
  reviewedById     String?
  adminNote        String?
  rejectionReason  String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  createdAt        DateTime      @default(now())
  deletedAt        DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id])
  plan           Plan?            @relation(fields: [planId], references: [id])
  paymentAccount PaymentAccount?  @relation(fields: [paymentAccountId], references: [id])
  proofAsset     MediaAsset?      @relation("PaymentProof", fields: [proofAssetId], references: [id])
  reviewedBy     User?            @relation("PaymentReviewer", fields: [reviewedById], references: [id])
  logs           PaymentRequestLog[]

  @@index([status, createdAt])
  @@index([tenantId])
  @@index([proofAssetId])
  @@index([reviewedById])
  @@index([tenantId, status])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  priority  String    @default("info")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model AdminNote {
  id        String    @id @default(cuid())
  tenantId  String
  authorId  String
  body      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("AdminNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([authorId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  tenantId    String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}

model ImpersonationSession {
  id          String    @id @default(cuid())
  adminUserId String
  tenantId    String
  reason      String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  admin  User   @relation("ImpersonationAdmin", fields: [adminUserId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([adminUserId, startedAt])
  @@index([tenantId, startedAt])
}

model SupportCase {
  id        String            @id @default(cuid())
  tenantId  String
  subject   String
  status    SupportCaseStatus @default(OPEN)
  priority  String            @default("normal")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, createdAt])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  key       String
  scope     FeatureFlagScope @default(PLATFORM)
  tenantId  String?
  siteId    String?
  enabled   Boolean          @default(false)
  value     Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  site   Site?   @relation(fields: [siteId], references: [id])

  @@unique([key, scope, tenantId, siteId])
  @@index([tenantId])
  @@index([siteId])
}

model BackupSettings {
  id             String     @id @default(cuid())
  type           BackupType @unique
  enabled        Boolean    @default(false)
  schedule       String
  retentionCount Int        @default(10)
  compression    String     @default("zstd")
  encryption     Boolean    @default(true)
  githubBranch   String     @default("platform-backups")
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  updatedAt      DateTime   @updatedAt
}

model BackupJob {
  id             String       @id @default(cuid())
  type           BackupType
  status         BackupStatus @default(PENDING)
  trigger        String
  initiatedById  String?
  note           String?
  sizeBytes      Int?
  checksumSha256 String?
  localPath      String?
  githubPath     String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())

  manifest    BackupManifest?
  initiatedBy User?           @relation("BackupInitiator", fields: [initiatedById], references: [id])

  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([initiatedById, createdAt])
}

model BackupManifest {
  id                       String   @id @default(cuid())
  backupJobId              String   @unique
  platformVersion          String
  gitCommitSha             String?
  databaseMigrationVersion String?
  usersCount               Int
  tenantsCount             Int
  sitesCount               Int
  mediaFilesCount          Int
  compressedSizeBytes      Int
  compressionAlgorithm     String
  encryptionEnabled        Boolean
  sha256Checksum           String
  localVerificationStatus  String
  githubUploadStatus       String
  durationMs               Int?
  uploadDurationMs         Int?
  createdAt                DateTime @default(now())

  backupJob BackupJob @relation(fields: [backupJobId], references: [id])
}

model RestoreJob {
  id              String   @id @default(cuid())
  backupId        String
  backupJobId     String?
  type            BackupType
  status          String   @default("PENDING")
  initiatedById   String?
  manifest        Json?
  validationJson  Json?
  resultJson      Json?
  postValidationJson Json?
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())

  initiatedBy User? @relation("RestoreInitiator", fields: [initiatedById], references: [id])

  @@index([backupId, createdAt])
  @@index([status, createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String?
  role         String    @default("SUPER_ADMIN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions AdminSession[]
}

model AdminSession {
  id          String   @id @default(cuid())
  adminUserId String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model ErrorLog {
  id             String   @id @default(cuid())
  code           String
  message        String
  category       String
  level          String
  requestId      String?
  correlationId  String?
  route          String?
  method         String?
  userId         String?
  tenantId       String?
  userAgent      String?
  platform       String?
  browser        String?
  stack          String?
  cause          String?
  metadata       Json?
  resolved       Boolean  @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  createdAt      DateTime @default(now())

  @@index([code, createdAt])
  @@index([category, createdAt])
  @@index([level, createdAt])
  @@index([userId])
  @@index([createdAt])
}

model NotificationLog {
  id        String    @id @default(cuid())
  type      String
  title     String
  body      String?
  category  String?
  userId    String?
  tenantId  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
}

model PaymentSettings {
  id            String        @id @default(cuid())
  paymentMethod PaymentMethod @unique
  isActive      Boolean       @default(true)
  label         String?
  description   String?
  config        Json          @default("{}")
  qrCodeAssetId String?
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  qrCodeAsset MediaAsset?       @relation("PaymentQRCode", fields: [qrCodeAssetId], references: [id])
  accounts    PaymentAccount[]

  @@index([isActive, sortOrder])
  @@index([qrCodeAssetId])
}

model PaymentAccount {
  id                String          @id @default(cuid())
  paymentSettingsId String
  label             String?
  accountName       String
  accountNumber     String
  bankName          String?
  iban              String?
  swift             String?
  phoneNumber       String?
  instructions      String?
  notes             String?
  isActive          Boolean         @default(true)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  paymentSettings  PaymentSettings @relation(fields: [paymentSettingsId], references: [id])
  paymentRequests  PaymentRequest[]

  @@index([paymentSettingsId, isActive])
}

model PaymentRequestLog {
  id               String   @id @default(cuid())
  paymentRequestId String
  action           String
  actorUserId      String?
  actorName        String?
  note             String?
  metadata         Json?
  createdAt        DateTime @default(now())

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id])

  @@index([paymentRequestId, createdAt])
}

model SubscriptionChange {
  id              String             @id @default(cuid())
  subscriptionId  String
  fromPlanId      String?
  toPlanId        String?
  fromStatus      SubscriptionStatus
  toStatus        SubscriptionStatus
  changeType      String
  reason          String?
  initiatedById   String?
  metadata        Json?
  createdAt       DateTime           @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  fromPlan     Plan?        @relation("FromPlan", fields: [fromPlanId], references: [id])
  toPlan       Plan?        @relation("ToPlan", fields: [toPlanId], references: [id])

  @@index([subscriptionId, createdAt])
}
