generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
  OPERATIONS_ADMIN
  BILLING_MANAGER
  TEMPLATE_MANAGER
  SUPPORT_AGENT
  SECURITY_AUDITOR
}

enum TenantStatus {
  TRIAL
  ACTIVE
  TRIAL_EXPIRED
  EXPIRED
  SUSPENDED
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  SUSPENDED
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum PaymentMethod {
  INSTAPAY
  VODAFONE_CASH
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  DRAFT
  SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum BackupType {
  DATABASE
  UPLOADS
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  VERIFICATION_FAILED
  UPLOAD_FAILED
}

enum SupportCaseStatus {
  OPEN
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum FeatureFlagScope {
  PLATFORM
  TENANT
  SITE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  passwordHash    String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  ownedTenants          Tenant[]
  auditLogs             AuditLog[]             @relation("AuditActor")
  adminNotes            AdminNote[]            @relation("AdminNoteAuthor")
  reviewedPayments      PaymentRequest[]       @relation("PaymentReviewer")
  backupJobs            BackupJob[]            @relation("BackupInitiator")
  backupRestores        RestoreJob[]           @relation("RestoreInitiator")
  impersonationSessions ImpersonationSession[] @relation("ImpersonationAdmin")
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]

  @@index([role, deletedAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Tenant {
  id                String       @id @default(cuid())
  ownerUserId       String
  displayName       String
  status            TenantStatus @default(TRIAL)
  trialStartedAt    DateTime     @default(now())
  trialEndsAt       DateTime
  trialDays         Int          @default(14)
  gracePeriodEndsAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  owner                 User                   @relation(fields: [ownerUserId], references: [id])
  sites                 Site[]
  mediaAssets           MediaAsset[]
  subscriptions         Subscription[]
  payments              PaymentRequest[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  adminNotes            AdminNote[]
  supportCases          SupportCase[]
  lifecycleEvents       LifecycleEvent[]
  featureFlags          FeatureFlag[]
  impersonationSessions ImpersonationSession[]

  @@index([ownerUserId, status])
}

model Site {
  id          String     @id @default(cuid())
  tenantId    String
  themeId     String
  slug        String     @unique
  title       String
  description String?
  templateCode    String?
  templateVersion String?
  status      SiteStatus @default(DRAFT)
  isPublished Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  theme            Theme             @relation(fields: [themeId], references: [id])
  domains          Domain[]
  themeConfigs     SiteThemeConfig[]
  sections         SiteSection[]
  galleryAlbums    GalleryAlbum[]
  contactProfile   ContactProfile?
  seoSettings      SEOSettings?
  lifecycleEvents  LifecycleEvent[]
  featureFlags     FeatureFlag[]
  packages         Package[]
  extraServices    ExtraService[]
  contentSnapshots SiteContentSnapshot[]

  @@index([tenantId, status])
  @@index([themeId])
  @@index([templateCode, templateVersion])
}

model Theme {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String
  category      String?
  defaultConfig Json
  contentSchema Json
  deletedAt     DateTime?

  sites            Site[]
  templates        Template[]
  siteThemeConfigs SiteThemeConfig[]
}

model Template {
  id            String      @id @default(cuid())
  themeId       String
  code          String      @unique
  name          String
  status        ThemeStatus @default(DRAFT)
  version       String      @default("1.0.0")
  showroomOrder Int         @default(0)
  coverAssetId  String?
  previewData   Json?
  settings      Json?
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  theme Theme @relation(fields: [themeId], references: [id])

  @@index([themeId, showroomOrder])
}

model SiteContentSnapshot {
  id              String   @id @default(cuid())
  siteId          String
  reason          String
  templateCode    String?
  templateVersion String?
  data            Json
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([templateCode, templateVersion])
}

model SiteThemeConfig {
  id        String    @id @default(cuid())
  siteId    String
  themeId   String
  config    Json
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site  Site  @relation(fields: [siteId], references: [id])
  theme Theme @relation(fields: [themeId], references: [id])

  @@unique([siteId, themeId])
}

model Domain {
  id        String       @id @default(cuid())
  siteId    String
  hostname  String       @unique
  status    DomainStatus @default(PENDING)
  verifiedAt DateTime?
  createdAt DateTime     @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model SiteSection {
  id        String    @id @default(cuid())
  siteId    String
  type      String
  title     String
  data      Json
  sortOrder Int       @default(0)
  isVisible Boolean   @default(true)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, sortOrder])
}

model GalleryAlbum {
  id            String    @id @default(cuid())
  siteId        String
  title         String
  slug          String    @default("")
  description   String?
  coverAssetId  String?
  isVisible     Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  site   Site        @relation(fields: [siteId], references: [id])
  cover  MediaAsset? @relation("AlbumCover", fields: [coverAssetId], references: [id])
  images GalleryImage[]

  @@index([siteId, sortOrder])
  @@index([coverAssetId])
}

model GalleryImage {
  id         String    @id @default(cuid())
  albumId    String
  assetId    String
  caption    String?
  alt        String?
  sortOrder  Int       @default(0)
  isFeatured Boolean   @default(false)
  deletedAt  DateTime?

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  asset MediaAsset   @relation(fields: [assetId], references: [id])

  @@index([albumId, sortOrder])
  @@index([assetId])
}

model MediaAsset {
  id             String    @id @default(cuid())
  tenantId       String
  kind           String    @default("image")
  url            String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  width          Int?
  height         Int?
  alt            String?
  checksumSha256 String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  paymentProofs  PaymentRequest[]  @relation("PaymentProof")
  galleryImages  GalleryImage[]
  albumCovers    GalleryAlbum[]    @relation("AlbumCover")
  contactAvatars ContactProfile[]  @relation("ContactAvatar")
  contactCovers  ContactProfile[]  @relation("ContactCover")
  seoOgImages    SEOSettings[]     @relation("SEOOgImage")
  paymentQRCodes PaymentAccount[]  @relation("PaymentQRCode")

  @@index([tenantId, kind, createdAt])
}

model ContactProfile {
  id                     String    @id @default(cuid())
  siteId                 String    @unique
  studioName             String?
  bio                    String?
  longDescription        String?
  phone                  String?
  whatsapp               String?
  email                  String?
  instagram              String?
  facebook               String?
  bookingMessageTemplate String?
  city                   String?
  country                String?
  address                String?
  googleMapsUrl          String?
  workingHours           Json?
  avatarAssetId          String?
  coverAssetId           String?
  tiktok                 String?
  snapchat               String?
  youtube                String?
  behance                String?
  fiveHundredPx          String?
  linkedin               String?
  telegram               String?
  xTwitter               String?
  threads                String?
  website                String?
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  site        Site        @relation(fields: [siteId], references: [id])
  avatarAsset MediaAsset? @relation("ContactAvatar", fields: [avatarAssetId], references: [id])
  coverAsset  MediaAsset? @relation("ContactCover", fields: [coverAssetId], references: [id])

  @@index([avatarAssetId])
  @@index([coverAssetId])
}

model SEOSettings {
  id                      String    @id @default(cuid())
  siteId                  String    @unique
  title                   String
  description             String?
  ogAssetId               String?
  robotsIndex             Boolean   @default(true)
  canonicalUrl            String?
  structuredDataOverrides Json?
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  site    Site        @relation(fields: [siteId], references: [id])
  ogAsset MediaAsset? @relation("SEOOgImage", fields: [ogAssetId], references: [id])

  @@index([ogAssetId])
}

model Package {
  id            String   @id @default(cuid())
  siteId        String
  name          String
  subtitle      String?
  priceAmount   Int
  currency      String   @default("EGP")
  features      Json
  imageUrl      String?
  isHighlighted Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  deletedAt     DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model ExtraService {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  description String?
  priceAmount Int
  currency    String   @default("EGP")
  iconKey     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  deletedAt   DateTime?

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, isActive, sortOrder])
}

model LifecycleEvent {
  id        String   @id @default(cuid())
  tenantId  String
  siteId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site?  @relation(fields: [siteId], references: [id])

  @@index([tenantId, createdAt])
}

model Plan {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  priceAmount     Int
  currency        String   @default("EGP")
  billingInterval String
  features        Json
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  subscriptions   Subscription[]
  paymentRequests PaymentRequest[]
  changesFrom     SubscriptionChange[] @relation("FromPlan")
  changesTo       SubscriptionChange[] @relation("ToPlan")

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  planId             String?
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  expiresAt          DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan?  @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
  @@index([expiresAt])
}

model SubscriptionChange {
  id         String   @id @default(cuid())
  tenantId   String
  fromPlanId String?
  toPlanId   String?
  reason     String?
  createdAt  DateTime @default(now())

  fromPlan Plan? @relation("FromPlan", fields: [fromPlanId], references: [id])
  toPlan   Plan? @relation("ToPlan", fields: [toPlanId], references: [id])
}

model PaymentRequest {
  id                String        @id @default(cuid())
  tenantId          String
  planId            String?
  amount            Int
  currency          String        @default("EGP")
  method            PaymentMethod
  status            PaymentStatus @default(DRAFT)
  reference         String?
  note              String?
  proofAssetId      String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now())
  deletedAt         DateTime?

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  plan         Plan?       @relation(fields: [planId], references: [id])
  proofAsset   MediaAsset? @relation("PaymentProof", fields: [proofAssetId], references: [id])
  reviewer     User?       @relation("PaymentReviewer", fields: [reviewedByUserId], references: [id])
  logs         PaymentRequestLog[]

  @@index([tenantId, status])
  @@index([proofAssetId])
}

model PaymentRequestLog {
  id             String         @id @default(cuid())
  requestId      String
  fromStatus     PaymentStatus?
  toStatus       PaymentStatus?
  action         String         @default("STATUS_CHANGED")
  actorUserId    String?
  actorName      String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  request PaymentRequest @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt])
}

model PaymentAccount {
  id                String        @id @default(cuid())
  method            PaymentMethod @default(INSTAPAY)
  displayName       String        @default("")
  accountIdentifier String        @default("")
  accountName       String        @default("")
  accountNumber     String        @default("")
  phoneNumber       String?
  bankName          String?
  qrAssetId         String?
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  deletedAt         DateTime?

  qrAsset MediaAsset? @relation("PaymentQRCode", fields: [qrAssetId], references: [id])

  @@index([method, isActive, sortOrder])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant  Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, readAt, createdAt])
}

model NotificationLog {
  id        String    @id @default(cuid())
  tenantId  String?
  category  String?
  type      String
  title     String
  body      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([tenantId, category, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         UserRole @default(SUPER_ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions AdminSession[]
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
}

model AdminNote {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("AdminNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
}

model ImpersonationSession {
  id        String   @id @default(cuid())
  adminId   String
  tenantId  String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  admin  User   @relation("ImpersonationAdmin", fields: [adminId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([adminId, createdAt])
  @@index([tenantId, createdAt])
}

model SupportCase {
  id          String            @id @default(cuid())
  tenantId    String
  openedById  String?
  status      SupportCaseStatus @default(OPEN)
  subject     String
  description String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  key       String
  scope     FeatureFlagScope @default(PLATFORM)
  tenantId  String?
  siteId    String?
  enabled   Boolean          @default(false)
  value     Json?
  updatedAt DateTime         @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  site   Site?   @relation(fields: [siteId], references: [id])

  @@unique([key, scope, tenantId, siteId])
}

model BackupJob {
  id               String       @id @default(cuid())
  type             BackupType
  status           BackupStatus @default(PENDING)
  triggeredById    String?
  filePath         String?
  sizeBytes        Int?
  checksumSha256   String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  completedAt      DateTime?

  triggeredBy User? @relation("BackupInitiator", fields: [triggeredById], references: [id])

  @@index([status, createdAt])
}

model BackupSettings {
  type            String   @id
  enabled         Boolean  @default(true)
  schedule        String   @default("0 2 * * *")
  retentionCount  Int      @default(7)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RestoreJob {
  id              String       @id @default(cuid())
  backupJobId     String
  status          BackupStatus @default(PENDING)
  triggeredById   String?
  targetDatabase  String?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  triggeredBy User? @relation("RestoreInitiator", fields: [triggeredById], references: [id])

  @@index([status, createdAt])
}

model ErrorLog {
  id             String    @id @default(cuid())
  category       String
  level          String
  code           String?
  message        String
  requestId      String?
  correlationId  String?
  route          String?
  userId         String?
  metadata       Json?
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  createdAt      DateTime  @default(now())

  @@index([category, level])
  @@index([createdAt])
  @@index([resolved])
}
